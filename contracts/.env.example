# Griddle contracts — deploy env
# Copy to .env, fill in blanks, then:
#   source .env && forge script script/Deploy.s.sol --rpc-url $BASE_RPC_URL --broadcast --verify

# From LHAW contracts/.env (same deployer key)
PRIVATE_KEY=

# From LHAW contracts/.env
BASE_RPC_URL=
BASESCAN_API_KEY=

# Escrow manager wallet (funded with $WORD + ETH for gas)
ESCROW_MANAGER_ADDRESS=0x2097D2C5127DF3f96876A360F4cbDAcfF82b9080

# LHAW JackpotManagerV3 — WordOracle adapter reads market cap from here.
# No oracle updater cron needed; LHAW backend feeds this automatically.
JACKPOT_MANAGER_ADDRESS=0xfcb0D07a5BB5B004A1580D5Ae903E33c4A79EdB5

# Optional: Ownable2Step owner. Defaults to deployer if unset.
# Recommend setting this to a hardware wallet address.
# OWNER=0x...
