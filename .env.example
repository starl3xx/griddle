# Database (M4a — Neon Postgres)
# Pooled connection — used by the runtime Drizzle client for app queries
DATABASE_URL=
# Unpooled connection — required for drizzle-kit migrations
# (pgbouncer drops prepared statements between queries and breaks DDL transactions)
DATABASE_URL_UNPOOLED=

# Upstash Redis (M4-perf) — read-through cache for today's puzzle row
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Site URL — used by lib/site.ts for metadata, OG, share footer
NEXT_PUBLIC_SITE_URL=https://griddle-fun.vercel.app

# Blockchain (M4)
NEXT_PUBLIC_WORD_TOKEN_ADDRESS=0x304e649e69979298BD1AEE63e175ADf07885fb4b
NEXT_PUBLIC_GRIDDLE_PREMIUM_ADDRESS=
NEXT_PUBLIC_GRIDDLE_REWARDS_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=8453

# Oracle (M4, extends LHAW CoinGecko oracle)
ORACLE_API_KEY=

# Puzzle scheduler
PUZZLE_SEED_SECRET=dev-only-change-me

# Anti-bot thresholds (server-side, tunable)
BOT_THRESHOLD_INELIGIBLE_MS=8000
BOT_THRESHOLD_SUSPICIOUS_MS=15000
BOT_THRESHOLD_STDDEV_MS=30
