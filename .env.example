# Database (M4a — Neon Postgres)
# Pooled connection — used by the runtime Drizzle client for app queries
DATABASE_URL=
# Unpooled connection — required for drizzle-kit migrations
# (pgbouncer drops prepared statements between queries and breaks DDL transactions)
DATABASE_URL_UNPOOLED=

# Upstash Redis (M4-perf) — read-through cache for today's puzzle row
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Site URL — used by lib/site.ts for metadata, OG, share footer
NEXT_PUBLIC_SITE_URL=https://griddle.fun

# Admin allowlist (M4d) — comma-separated lowercase 0x addresses.
# Wallets in this list can view /admin/anomalies. Empty = no admins.
ADMIN_WALLETS=

# Blockchain (M4)
NEXT_PUBLIC_WORD_TOKEN_ADDRESS=0x304e649e69979298BD1AEE63e175ADf07885fb4b
NEXT_PUBLIC_GRIDDLE_PREMIUM_ADDRESS=   # set after M4e deploy
NEXT_PUBLIC_GRIDDLE_REWARDS_ADDRESS=   # set after M4e deploy
NEXT_PUBLIC_CHAIN_ID=8453

# Contracts deploy (contracts/.env — see contracts/README.md for full list:
# PRIVATE_KEY, BASE_RPC_URL, BASESCAN_API_KEY, ORACLE_ADDRESS,
# ESCROW_MANAGER_ADDRESS, REWARD_SIGNER_ADDRESS, OWNER (optional))

# Oracle (M4, extends LHAW CoinGecko oracle)
ORACLE_API_KEY=

# Puzzle scheduler
PUZZLE_SEED_SECRET=dev-only-change-me

# Anti-bot thresholds (server-side, tunable)
BOT_THRESHOLD_INELIGIBLE_MS=8000
BOT_THRESHOLD_SUSPICIOUS_MS=15000
BOT_THRESHOLD_STDDEV_MS=30

# Stripe (M4f — fiat checkout path)
# Secret key + webhook signing secret are server-only, never exposed to the client.
# Publishable key is not currently needed because we use Stripe Checkout (hosted page).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price id for Griddle Premium — one-time $6 charge, lookup key `griddle_premium_v1`
# Use your TEST-mode price id locally; the live id is set in Vercel env config.
STRIPE_PRICE_ID=
